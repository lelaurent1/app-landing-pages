{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "anthropic/claude-opus-4.6": {
          "options": {
            "reasoning": {
              "enabled": true,
              "effort": "high"
            },
            "extraBody": {
              "verbosity": "high"
            }
          }
        }
      }
    }
  },
  "mcp": {
    "mcp__playwright_": {
      "type": "local",
      "enabled": true,
      "command": [
        "bunx",
        "@playwright/mcp@0.0.39",
        "--headless",
        "--browser",
        "chromium",
        "--no-sandbox",
        "--isolated"
      ]
    }
  }
}
